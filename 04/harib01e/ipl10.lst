     1                                  ; hello-os
     2                                  ; TAB=4
     3                                  
     4                                  		CYLS	EQU	10
     5                                  		ORG 0x7c00	; Where to start the program
     6                                  
     7                                  ; For FAT12(floppy disc) format
     8                                  
     9 00000000 EB4E                    		JMP     entry
    10 00000002 90                      		DB      0x90
    11 00000003 48454C4C4F49504C        		DB      "HELLOIPL"
    12 0000000B 0002                    		DW      512
    13 0000000D 01                      		DB      1
    14 0000000E 0100                    		DW      1
    15 00000010 02                      		DB      2
    16 00000011 E000                    		DW      224
    17 00000013 400B                    		DW      2880
    18 00000015 F0                      		DB      0xf0
    19 00000016 0900                    		DW      9
    20 00000018 1200                    		DW      18
    21 0000001A 0200                    		DW      2
    22 0000001C 00000000                		DD      0
    23 00000020 400B0000                		DD      2880
    24 00000024 000029                  		DB      0,0,0x29
    25 00000027 FFFFFFFF                		DD      0xffffffff
    26 0000002B 48415249424F54454F-     		DB      "HARIBOTEOS "
    26 00000034 5320               
    27 00000036 4641543132202020        		DB      "FAT12   "
    28 0000003E 00<rep 12h>             		TIMES   18 DB 0
    29                                  
    30                                  ; Main
    31                                  
    32                                  entry:
    33 00000050 B80000                  		MOV 	AX,0
    34 00000053 8ED0                    		MOV		SS, AX
    35 00000055 BC007C                  		MOV		SP,0x7c00
    36 00000058 8ED8                    		MOV		DS,AX
    37                                  
    38                                  ; Read disc
    39                                      
    40 0000005A B82008                      MOV   AX,0x0820
    41 0000005D 8EC0                        MOV   ES,AX
    42 0000005F B500                        MOV   CH,0
    43 00000061 B600                        MOV   DH,0
    44 00000063 B102                        MOV   CL,2
    45                                  readloop:
    46 00000065 BE0000                  		MOV		SI,0
    47                                  retry:
    48 00000068 B402                        MOV   AH,0x02
    49 0000006A B001                        MOV   AL,1
    50 0000006C BB0000                      MOV   BX,0
    51 0000006F B200                        MOV   DL,0x00
    52 00000071 CD13                        INT   0x13
    53 00000073 7310                    		JNC		next
    54 00000075 83C601                  		ADD		SI,1
    55 00000078 83FE05                  		CMP		SI,5
    56 0000007B 7335                    		JAE		error
    57 0000007D B400                    		MOV		AH,0x00
    58 0000007F B200                    		MOV		DL,0x00
    59 00000081 CD13                    		INT		0x13
    60 00000083 EBE3                        JMP   retry
    61                                  next:
    62 00000085 8CC0                    		MOV		AX, ES
    63 00000087 83C020                  		ADD		AX,0x0020
    64 0000008A 8EC0                    		MOV		ES,AX
    65 0000008C 80C101                  		ADD		CL,1
    66 0000008F 80F912                  		CMP		CL,18
    67 00000092 76D1                    		JBE		readloop
    68 00000094 B101                    		MOV		CL,1
    69 00000096 80C601                  		ADD		DH,1
    70 00000099 80FE02                  		CMP		DH,2
    71 0000009C 72C7                    		JB		readloop
    72 0000009E B600                    		MOV		DH,0
    73 000000A0 80C501                  		ADD		CH,1
    74 000000A3 80FD0A                  		CMP		CH,CYLS
    75 000000A6 72BD                    		JB		readloop
    76                                  ; 全て終わった時
    77 000000A8 882EF00F                		MOV		[0x0ff0],CH
    78 000000AC E9(00C2)                		JMP		0xc200
    79                                  
    80                                  fin:
    81 000000AF F4                      		HLT
    82 000000B0 EBFD                    		JMP		fin
    83                                  error:
    84 000000B2 BE[C700]                    MOV   SI,msg
    85                                  putloop:
    86 000000B5 8A04                    		MOV		AL,[SI]
    87 000000B7 83C601                  		ADD		SI,1
    88 000000BA 3C00                    		CMP		AL,0
    89 000000BC 74F1                    		JE		fin
    90 000000BE B40E                    		MOV		AH,0x0e
    91 000000C0 BB0F00                  		MOV		BX,15
    92 000000C3 CD10                    		INT		0x10
    93 000000C5 EBEE                    		JMP		putloop
    94                                  msg:
    95 000000C7 0A0A                    		DB      0x0a, 0x0a
    96 000000C9 6C6F6164206572726F-     		DB      "load error"
    96 000000D2 72                 
    97 000000D3 0A                      		DB      0x0a
    98 000000D4 00                      		DB      0
    99 000000D5 00<rep 129h>            		TIMES   0x1fe-($-$$) DB 0
   100 000001FE 55AA                    		DB      0x55, 0xaa
